<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Turban Creations - Student Registration</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:#f5f5f5;
      color:#222;
    }

    .navbar{
      background:#000;
      padding:15px 40px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
    }

    .logo-section{
      display:flex;
      align-items:center;
      gap:15px;
    }

    .logo-section img{
      width:70px;
      height:70px;
      border-radius:50%;
      object-fit:cover;
      border:2px solid #d4af37;
    }

    .brand-name{
      color:#fff;
    }

    .brand-name h1{
      font-size:28px;
      color:#d4af37;
    }

    .brand-name p{
      font-size:14px;
      color:#ddd;
    }

    .social-links{
      display:flex;
      gap:15px;
      margin-top:10px;
    }

    .social-links a{
      text-decoration:none;
      color:white;
      background:#d4af37;
      padding:10px 18px;
      border-radius:8px;
      font-size:14px;
      transition:0.3s;
    }

    .social-links a:hover{
      background:white;
      color:black;
    }

    .hero{
      background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
      url('images/turban-bg.jpg');
      background-size:cover;
      background-position:center;
      padding:80px 20px;
      text-align:center;
      color:white;
    }

    .hero h2{
      font-size:42px;
      margin-bottom:15px;
      color:#d4af37;
    }

    .hero p{
      max-width:800px;
      margin:auto;
      line-height:1.8;
      font-size:17px;
    }

    .form-container{
      width:90%;
      max-width:700px;
      background:white;
      margin:50px auto;
      padding:40px;
      border-radius:15px;
      box-shadow:0 5px 20px rgba(0,0,0,0.1);
    }

    .form-container h2{
      text-align:center;
      margin-bottom:30px;
      color:#d4af37;
      font-size:32px;
    }

    .input-group{
      margin-bottom:20px;
    }

    .input-group label{
      display:block;
      margin-bottom:8px;
      font-weight:500;
    }

    .input-group input,
    .input-group select,
    .input-group textarea{
      width:100%;
      padding:14px;
      border:1px solid #ccc;
      border-radius:10px;
      font-size:15px;
      font-family:'Poppins',sans-serif;
    }

    .input-group textarea{
      resize:none;
      height:100px;
    }

    .submit-btn{
      width:100%;
      padding:15px;
      border:none;
      background:#d4af37;
      color:black;
      font-size:18px;
      border-radius:10px;
      cursor:pointer;
      font-weight:600;
      transition:0.3s;
    }

    .submit-btn:hover{
      background:black;
      color:white;
    }

    .info-section{
      width:90%;
      max-width:1100px;
      margin:40px auto;
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
    }

    .info-card{
      background:white;
      padding:25px;
      border-radius:15px;
      text-align:center;
      box-shadow:0 5px 15px rgba(0,0,0,0.08);
    }

    .info-card h3{
      color:#d4af37;
      margin-bottom:12px;
    }

    .footer{
      background:black;
      color:white;
      padding:40px 20px;
      text-align:center;
      margin-top:50px;
    }

    .footer h2{
      color:#d4af37;
      margin-bottom:15px;
    }

    .footer p{
      line-height:1.8;
      color:#ccc;
    }

    @media(max-width:768px){

      .navbar{
        flex-direction:column;
        gap:20px;
      }

      .hero h2{
        font-size:32px;
      }

      .form-container{
        padding:25px;
      }

    }

  </style>
</head>
<body>

  <nav class="navbar">

    <div class="logo-section">

      <img src="images/logo.png" alt="Turban Creations Logo">

      <div class="brand-name">
        <h1>Turban Creations</h1>
        <p>Royal Turban Styling & Professional Turban Classes</p>
      </div>

    </div>

    <div class="social-links">
      <a href="https://instagram.com/yourusername" target="_blank">Instagram</a>
      <a href="https://facebook.com/yourusername" target="_blank">Facebook</a>
      <a href="https://youtube.com/yourusername" target="_blank">YouTube</a>
    </div>

  </nav>


  <section class="hero">

    <h2>Student Registration Form</h2>

    <p>
      Join Turban Creations Professional Turban Classes and learn traditional,
      royal and modern turban styling techniques with practical guidance.
      Register now to reserve your seat.
    </p>

  </section>


  <section class="form-container">

    <h2>Register Now</h2>

    <form id="studentForm">

      <div class="input-group">
        <label>Full Name</label>
        <input type="text" id="name" placeholder="Enter Full Name" required>
      </div>

      <div class="input-group">
        <label>Phone Number</label>
        <input type="tel" id="phone" placeholder="Enter Phone Number" required>
      </div>

      <div class="input-group">
        <label>Email Address</label>
        <input type="email" id="email" placeholder="Enter Email Address">
      </div>

      <div class="input-group">
        <label>Select Course</label>

        <select id="course" required>
          <option value="">Choose Course</option>
          <option>Basic Turban Tying</option>
          <option>Wedding Turban Styling</option>
          <option>Royal Punjabi Turban</option>
          <option>Family Theme Turban Styling</option>
          <option>Professional Turban Artist Training</option>
        </select>
      </div>

      <div class="input-group">
        <label>Course Fees</label>
        <input type="number" id="fees" placeholder="Enter Fees Amount" required>
      </div>

      <div class="input-group">
        <label>Address</label>
        <textarea id="address" placeholder="Enter Full Address"></textarea>
      </div>

      <div class="input-group">
        <label>Additional Notes</label>
        <textarea id="notes" placeholder="Write any message or requirement"></textarea>
      </div>

      <button type="submit" class="submit-btn">
        Submit Registration
      </button>

    </form>

  </section>


  <section class="info-section">

    <div class="info-card">
      <h3>Class Timing</h3>
      <p>
        Morning & Evening Batches Available
      </p>
    </div>

    <div class="info-card">
      <h3>Location</h3>
      <p>
        Ludhiana, Punjab, India
      </p>
    </div>

    <div class="info-card">
      <h3>Contact</h3>
      <p>
        +91 XXXXX XXXXX<br>
        turbancreations@gmail.com
      </p>
    </div>

  </section>


  <footer class="footer">

    <h2>Turban Creations</h2>

    <p>
      Preserving Punjabi heritage with professional turban styling,
      wedding services and training classes.
    </p>

    <br>

    <p>
      © 2026 Turban Creations. All Rights Reserved.
    </p>

  </footer>


  <script type="module" src="students.js"></script>

</body>
</html>
